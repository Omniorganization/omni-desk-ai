{
  "include": [
    "omnidesk_agent/core",
    "omnidesk_agent/security",
    "omnidesk_agent/tools",
    "omnidesk_agent/self_upgrade",
    "omnidesk_agent/storage",
    "omnidesk_agent/repositories/postgres_state.py",
    "omnidesk_agent/appsync/postgres_migrations.py",
    "omnidesk_agent/appsync/migrate.py",
    "omnidesk_agent/appsync/strict_json_store.py",
    "omnidesk_agent/appsync/factory.py",
    "omnidesk_agent/appsync/migrated_postgres_store.py",
    "omnidesk_agent/models/router_streaming.py",
    "omnidesk_agent/server.py",
    "omnidesk_agent/daemon.py"
  ],
  "exclude": [
    "**/__pycache__",
    ".venv",
    "build",
    "dist"
  ],
  "strict": [
    "omnidesk_agent/appsync/postgres_migrations.py",
    "omnidesk_agent/appsync/strict_json_store.py"
  ],
  "pythonVersion": "3.10",
  "typeCheckingMode": "basic",
  "reportMissingImports": "warning",
  "reportMissingTypeStubs": "none",
  "reportUnknownArgumentType": "warning",
  "reportUnknownMemberType": "warning",
  "reportUntypedFunctionDecorator": "warning"
}
