{
  "productName": "Omni Desktop",
  "version": "1.12.7",
  "identifier": "ai.omnidesk.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Omni Desktop Runtime", "width": 1180, "height": 760 }],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* https: ws: wss:; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true
  }
}
