{
  "name": "Omni Tri-App Sync API",
  "version": "1.12.7+root-monorepo-production-ga-candidate",
  "auth": {
    "type": "bearer",
    "roles": [
      "viewer",
      "operator",
      "owner"
    ],
    "headers": [
      "Authorization: Bearer <token>",
      "X-OmniDesk-Actor: <actor>",
      "Idempotency-Key: <operation-key>",
      "X-OmniDesk-Device-Id: <device-id>",
      "X-OmniDesk-Timestamp: <unix-ms>",
      "X-OmniDesk-Nonce: <random-nonce>",
      "X-OmniDesk-Device-Signature: <base64-signature>"
    ],
    "device_signature": "For enrolled desktop/mobile/web_admin devices, production sensitive requests must sign: method, path, SHA-256 body hash, timestamp, and nonce. Nonces are one-use replay guards.",
    "websocket": "Authorization header preferred; query token remains development-only compatibility mode"
  },
  "surfaces": [
    "desktop",
    "mobile",
    "web_admin"
  ],
  "client_surface_policy": "Each endpoint declares client_surfaces. Typed client contract tests are generated from this field; endpoints with an empty list are server/API-only and must not be required by tri-app clients.",
  "endpoints": [
    {
      "method": "GET",
      "path": "/app/bootstrap",
      "role": "viewer",
      "client_surfaces": [
        "desktop",
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "GET",
      "path": "/app/projects",
      "description": "List user-created projects in the caller organization for Web Admin, Desktop, and Mobile project synchronization.",
      "role": "viewer",
      "client_surfaces": [
        "desktop",
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/projects",
      "description": "Create a user-owned project and emit a project.created sync event. No default projects are provisioned by the Gateway.",
      "role": "operator",
      "client_surfaces": [
        "desktop",
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "PATCH",
      "path": "/app/projects/{project_id}",
      "description": "Rename or update metadata for a user-created project within the caller organization.",
      "role": "operator",
      "client_surfaces": [
        "desktop",
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "DELETE",
      "path": "/app/projects/{project_id}",
      "description": "Soft-delete a user-created project and emit a project.deleted sync event.",
      "role": "operator",
      "client_surfaces": [
        "desktop",
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/devices/register",
      "role": "operator",
      "client_surfaces": [
        "desktop",
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "GET",
      "path": "/app/conversations",
      "role": "viewer",
      "client_surfaces": [
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/conversations",
      "role": "operator",
      "client_surfaces": [
        "desktop",
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/conversations/{conversation_id}/messages",
      "role": "operator",
      "client_surfaces": [
        "mobile"
      ]
    },
    {
      "method": "GET",
      "path": "/app/conversations/{conversation_id}/messages",
      "role": "viewer",
      "client_surfaces": [
        "desktop",
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/conversations/{conversation_id}/ask",
      "description": "Create a Gateway-audited chat turn, call the configured ModelRouter with task=chat, persist user and assistant messages, and return model metadata without exposing provider credentials to clients.",
      "role": "operator",
      "client_surfaces": [
        "desktop",
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/api/chat",
      "description": "Unified non-streaming chat entrypoint for Web, Desktop, Mobile, and API clients. Creates or reuses a conversation, calls the governed ModelRouter with task=chat, persists user/assistant messages, and returns audit trace metadata.",
      "role": "operator",
      "client_surfaces": []
    },
    {
      "method": "POST",
      "path": "/api/chat/stream",
      "description": "Reserved streaming chat entrypoint. This source-gated candidate fails closed with 501 until streaming transport, audit chunking, and client handling are production-gated.",
      "role": "operator",
      "client_surfaces": []
    },
    {
      "method": "GET",
      "path": "/app/tasks/{task_id}",
      "role": "viewer",
      "client_surfaces": []
    },
    {
      "method": "POST",
      "path": "/app/tasks/{task_id}/status",
      "role": "operator",
      "client_surfaces": [
        "desktop"
      ],
      "signed_device_required_in_production": [
        "desktop"
      ]
    },
    {
      "method": "GET",
      "path": "/app/approvals",
      "role": "viewer",
      "client_surfaces": [
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/approvals/{approval_id}/decide",
      "role": "owner",
      "client_surfaces": [
        "mobile",
        "web_admin"
      ],
      "signed_device_required_in_production": [
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "GET",
      "path": "/app/notifications",
      "role": "viewer",
      "client_surfaces": [
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/runtime/desktop/heartbeat",
      "role": "operator",
      "client_surfaces": [
        "desktop"
      ],
      "signed_device_required_in_production": [
        "desktop"
      ]
    },
    {
      "method": "POST",
      "path": "/app/runtime/desktop/claim",
      "role": "operator",
      "client_surfaces": [
        "desktop"
      ],
      "signed_device_required_in_production": [
        "desktop"
      ]
    },
    {
      "method": "GET",
      "path": "/app/sync",
      "role": "viewer",
      "client_surfaces": [
        "desktop"
      ]
    },
    {
      "method": "POST",
      "path": "/app/sync",
      "role": "operator",
      "client_surfaces": []
    },
    {
      "method": "GET",
      "path": "/app/sync/state",
      "role": "viewer",
      "client_surfaces": []
    },
    {
      "method": "WS",
      "path": "/app/ws",
      "role": "gateway-protected",
      "client_surfaces": []
    },
    {
      "method": "POST",
      "path": "/app/devices/{device_id}/push-token",
      "role": "operator",
      "client_surfaces": [
        "desktop",
        "mobile"
      ],
      "signed_device_required_in_production": [
        "desktop",
        "mobile"
      ]
    },
    {
      "method": "POST",
      "path": "/app/devices/enrollment/start",
      "role": "owner",
      "client_surfaces": [
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/devices/enrollment/{enrollment_id}/complete",
      "role": "operator",
      "client_surfaces": [
        "desktop",
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/devices/enrollment/{enrollment_id}/challenge",
      "description": "Issue a nonce challenge for device credential verification.",
      "role": "operator",
      "client_surfaces": [
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/devices/enrollment/{enrollment_id}/verify",
      "description": "Verify a signed device challenge and mint a device credential.",
      "role": "operator",
      "client_surfaces": [
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/devices/{device_id}/rotate-token",
      "description": "Rotate a device token hash after successful device authentication.",
      "role": "operator",
      "client_surfaces": [],
      "signed_device_required_in_production": [
        "desktop",
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/devices/{device_id}/revoke",
      "description": "Revoke a desktop/mobile/web_admin device credential.",
      "role": "owner",
      "client_surfaces": [],
      "signed_device_required_in_production": [
        "mobile",
        "web_admin"
      ]
    },
    {
      "method": "POST",
      "path": "/app/push/dispatch",
      "description": "Dispatch pending push outbox items through the configured provider.",
      "role": "owner",
      "client_surfaces": []
    }
  ],
  "shared_objects": [
    "Organization",
    "UserProfile",
    "ProjectRecord",
    "DeviceRecord",
    "ConversationRecord",
    "MessageRecord",
    "TaskRecord",
    "ApprovalRecord",
    "NotificationRecord",
    "RuntimeStatusRecord",
    "SyncEvent",
    "IdempotencyRecord",
    "TaskLease",
    "DeviceEnrollmentRecord",
    "PushRegistration",
    "PostgresNormalizedSchema",
    "DeviceCredentialChallenge"
  ]
}
