{
  "schema": "omnidesk-branch-protection/v1",
  "protected_branch": "main",
  "allow_direct_pushes": false,
  "allow_deletions": false,
  "require_pull_request": true,
  "require_branch_up_to_date": true,
  "require_conversation_resolution": true,
  "require_codeowners_review": true,
  "dismiss_stale_reviews": true,
  "require_signed_commits": true,
  "required_approving_review_count": 1,
  "required_status_checks": [
    "Release Policy",
    "CI",
    "Security",
    "Docker Image Scan",
    "Tri-App Quality Gate",
    "Main Verification",
    "Self Upgrade Gate"
  ],
  "required_jobs": [
    "release-policy",
    "external-ga-evidence-contract",
    "test (3.10)",
    "test (3.11)",
    "test (3.12)",
    "test (3.13)",
    "web-admin",
    "desktop-tauri",
    "mobile-flutter",
    "mobile-ios-simulator",
    "backend-and-contract",
    "main-verification"
  ],
  "restricted_paths": [
    ".github/",
    "scripts/",
    "deploy/",
    "omnidesk_agent/security/",
    "release/"
  ],
  "merge_policy": {
    "require_all_required_checks_success": true,
    "block_pending_required_checks": true,
    "require_branch_up_to_date": true,
    "require_conversation_resolution": true,
    "require_code_owner_review": true,
    "dismiss_stale_reviews": true,
    "require_signed_commits": true
  },
  "distribution_ga_policy": {
    "require_main_verification_artifact": true,
    "require_external_ga_evidence_passed": true,
    "forbid_mock_or_sample_evidence": true
  }
}
