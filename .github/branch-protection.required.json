{
  "schema": "omnidesk-branch-protection/v1",
  "protected_branch": "main",
  "allow_direct_pushes": false,
  "allow_deletions": false,
  "require_pull_request": true,
  "require_branch_up_to_date": true,
  "require_conversation_resolution": true,
  "require_codeowners_review": true,
  "dismiss_stale_reviews": true,
  "require_signed_commits": true,
  "require_enforce_admins": true,
  "require_linear_history": true,
  "required_approving_review_count": 1,
  "required_status_checks": [
    "Release Policy",
    "release-policy",
    "external-ga-evidence-contract",
    "CI",
    "Security",
    "Security Attack Surface Gate",
    "Docker Image Scan",
    "Tri-App Quality Gate",
    "Main Verification",
    "Team Governance",
    "Self Upgrade Gate",
    "Source Maturity Closure",
    "P0 P1 P2 Feasible Closure",
    "Remaining Real GA Source Fixes"
  ],
  "required_jobs": [
    "release-policy",
    "external-ga-evidence-contract",
    "test (3.10)",
    "test (3.11)",
    "test (3.12)",
    "test (3.13)",
    "web-admin",
    "desktop-tauri",
    "mobile-flutter",
    "mobile-ios-simulator",
    "backend-and-contract",
    "main-verification",
    "team-governance",
    "security-attack-surface",
    "source-maturity-closure",
    "feasible-closure",
    "remaining-real-evidence-source-fixes"
  ],
  "restricted_paths": [
    ".github/",
    "scripts/",
    "deploy/",
    "omnidesk_agent/security/",
    "release/"
  ],
  "merge_policy": {
    "require_all_required_checks_success": true,
    "block_pending_required_checks": true,
    "require_branch_up_to_date": true,
    "require_conversation_resolution": true,
    "require_code_owner_review": true,
    "dismiss_stale_reviews": true,
    "require_signed_commits": true,
    "require_enforce_admins": true,
    "require_linear_history": true
  },
  "team_governance": {
    "required_for_customer_distribution_ga": true,
    "source_contract": ".github/team-governance.required.json",
    "live_evidence": "release/external-evidence/control-plane/github-team-governance-live.json",
    "require_organization_owner": true,
    "require_resolved_github_teams": true,
    "forbid_personal_owner_fallback_for_real_ga": true
  },
  "distribution_ga_policy": {
    "require_main_verification_artifact": true,
    "require_main_verification_live_artifact": true,
    "require_team_codeowners": true,
    "require_external_ga_evidence_passed": true,
    "forbid_mock_or_sample_evidence": true
  }
}
