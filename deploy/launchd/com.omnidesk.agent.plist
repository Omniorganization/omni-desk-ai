<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.omnidesk.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/omnidesk</string>
    <string>--config</string><string>~/.omnidesk/config.yaml</string>
    <string>serve</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>~/.omnidesk/launchd.out.log</string>
  <key>StandardErrorPath</key><string>~/.omnidesk/launchd.err.log</string>
</dict>
</plist>
