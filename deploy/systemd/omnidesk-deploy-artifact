#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage: omnidesk-deploy-artifact --artifact PATH --sha256 SHA256 --expected-version VERSION [--image-digest sha256:DIGEST]

Fixed remote systemd deploy helper for OmniDesk artifacts. It verifies the
uploaded artifact, installs it into a dedicated virtualenv, writes runtime
identity environment variables, restarts the systemd service, runs a local
health check, and rolls back to the previous wheel on failure.

Environment:
  OMNIDESK_SYSTEMD_SERVICE        default: omnidesk-agent
  OMNIDESK_INSTALL_DIR            default: /opt/omnidesk
  OMNIDESK_RUNTIME_ENV_FILE       default: /etc/omnidesk/runtime.env
  OMNIDESK_HEALTH_URL             default: http://127.0.0.1:18789/health
USAGE
}

is_sha256() { [[ "$1" =~ ^[0-9a-f]{64}$ ]]; }
is_image_digest() { [[ -z "$1" || "$1" =~ ^sha256:[0-9a-f]{64}$ ]]; }

ARTIFACT=""
EXPECTED_SHA=""
EXPECTED_VERSION=""
IMAGE_DIGEST=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --artifact) ARTIFACT="${2:-}"; shift 2 ;;
    --sha256) EXPECTED_SHA="${2:-}"; shift 2 ;;
    --expected-version) EXPECTED_VERSION="${2:-}"; shift 2 ;;
    --image-digest) IMAGE_DIGEST="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown argument: $1" >&2; usage; exit 64 ;;
  esac
done

SERVICE="${OMNIDESK_SYSTEMD_SERVICE:-omnidesk-agent}"
INSTALL_DIR="${OMNIDESK_INSTALL_DIR:-/opt/omnidesk}"
VENV_DIR="$INSTALL_DIR/venv"
ARTIFACT_DIR="$INSTALL_DIR/artifacts"
RUNTIME_ENV_FILE="${OMNIDESK_RUNTIME_ENV_FILE:-/etc/omnidesk/runtime.env}"
HEALTH_URL="${OMNIDESK_HEALTH_URL:-http://127.0.0.1:18789/health}"

if [[ -z "$ARTIFACT" || -z "$EXPECTED_SHA" || -z "$EXPECTED_VERSION" ]]; then
  usage
  exit 64
fi
if [[ ! -f "$ARTIFACT" ]]; then
  echo "artifact not found: $ARTIFACT" >&2
  exit 66
fi
if ! is_sha256 "$EXPECTED_SHA"; then
  echo "--sha256 must be a lowercase 64-character sha256 digest" >&2
  exit 64
fi
if ! is_image_digest "$IMAGE_DIGEST"; then
  echo "--image-digest must be sha256:<64 hex chars> when provided" >&2
  exit 64
fi

actual_sha="$(sha256sum "$ARTIFACT" | awk '{print $1}')"
if [[ "$actual_sha" != "$EXPECTED_SHA" ]]; then
  echo "artifact sha256 mismatch: expected $EXPECTED_SHA got $actual_sha" >&2
  exit 65
fi

mkdir -p "$ARTIFACT_DIR" "$(dirname "$RUNTIME_ENV_FILE")"
cp "$ARTIFACT" "$ARTIFACT_DIR/omnidesk-$EXPECTED_VERSION-$actual_sha.whl"
PREVIOUS_WHEEL="$(readlink -f "$ARTIFACT_DIR/current.whl" 2>/dev/null || true)"
ln -sfn "$ARTIFACT_DIR/omnidesk-$EXPECTED_VERSION-$actual_sha.whl" "$ARTIFACT_DIR/current.whl"

rollback() {
  code=$?
  if [[ $code -ne 0 && -n "$PREVIOUS_WHEEL" && -f "$PREVIOUS_WHEEL" ]]; then
    echo "Deploy failed; rolling back to $PREVIOUS_WHEEL" >&2
    ln -sfn "$PREVIOUS_WHEEL" "$ARTIFACT_DIR/current.whl"
    "$VENV_DIR/bin/python" -m pip install --no-deps --force-reinstall "$PREVIOUS_WHEEL" || true
    systemctl restart "$SERVICE" || true
  fi
  exit $code
}
trap rollback EXIT

if [[ ! -x "$VENV_DIR/bin/python" ]]; then
  python3 -m venv "$VENV_DIR"
fi
"$VENV_DIR/bin/python" -m pip install --no-deps --force-reinstall "$ARTIFACT_DIR/current.whl"

cat > "$RUNTIME_ENV_FILE" <<ENV
OMNIDESK_VERSION=$EXPECTED_VERSION
OMNIDESK_ARTIFACT_SHA256=$actual_sha
OMNIDESK_IMAGE_DIGEST=$IMAGE_DIGEST
ENV

systemctl daemon-reload
systemctl restart "$SERVICE"
systemctl is-active "$SERVICE" >/dev/null

"$VENV_DIR/bin/python" - <<PY
import json, urllib.request, sys
url = ${HEALTH_URL@Q}
expected_version = ${EXPECTED_VERSION@Q}
expected_sha = ${actual_sha@Q}
with urllib.request.urlopen(url, timeout=10) as r:
    payload = json.loads(r.read().decode('utf-8'))
if payload.get('version') != expected_version:
    raise SystemExit(f"runtime version mismatch: expected {expected_version}, got {payload.get('version')}")
if payload.get('artifact_sha256') != expected_sha:
    raise SystemExit(f"runtime artifact sha mismatch: expected {expected_sha}, got {payload.get('artifact_sha256')}")
print('systemd artifact deploy verified')
PY

trap - EXIT
