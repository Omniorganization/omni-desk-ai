OMNIDESK_ENV=production
OMNIDESK_SANDBOX_RUNNER_HOST=127.0.0.1
OMNIDESK_SANDBOX_RUNNER_PORT=18890
OMNIDESK_CONTAINER_RUNTIME=docker
OMNIDESK_SANDBOX_RUNNER_TOKEN=replace-with-32-plus-char-random-token
OMNIDESK_SANDBOX_RUNNER_HMAC_SECRET=replace-with-32-plus-char-random-hmac-secret
OMNIDESK_SANDBOX_IMAGE=python:3.11-slim@sha256:f9fa7f851e38bfb19c9de3afbc4b86ae7176ea7aaf94535c31df5458d5849457
OMNIDESK_SANDBOX_IMAGE_ALLOWLIST=python:3.11-slim@sha256:f9fa7f851e38bfb19c9de3afbc4b86ae7176ea7aaf94535c31df5458d5849457
OMNIDESK_SANDBOX_ALLOWED_WORKSPACE_ROOT=/srv/omnidesk-sandbox-workspaces
OMNIDESK_SANDBOX_ALLOW_WORKSPACE_PATHS=0
OMNIDESK_SANDBOX_READY_SMOKE=1
OMNIDESK_SANDBOX_MAX_TIMEOUT=180
OMNIDESK_SANDBOX_MAX_OUTPUT_CHARS=12000
