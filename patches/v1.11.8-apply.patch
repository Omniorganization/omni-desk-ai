# OmniDesk 1.11.8 semantic hardening patch.
# Review before applying. This patch is additive and must not be applied on top of an already-hardened tree.
# Historical patches remain under patches/archive/ and must not be applied to current releases.

diff --git a/.github/workflows/release.yml b/.github/workflows/release.yml
--- a/.github/workflows/release.yml
+++ b/.github/workflows/release.yml
@@
+      - name: Run tri-app release configuration preflight scopes
+        run: |
+          python scripts/check_release_configuration.py --scope web-admin --format json --report-path dist/web-admin-preflight.json
+          python scripts/check_release_configuration.py --scope desktop --format json --report-path dist/desktop-preflight.json
+          python scripts/check_release_configuration.py --scope mobile --format json --report-path dist/mobile-preflight.json
+          python scripts/check_release_configuration.py --scope tri-app --format json --report-path dist/tri-app-preflight.json
+      - name: Import iOS real-device evidence
+        env:
+          IOS_EVIDENCE_RAW_DIR: ${{ vars.IOS_EVIDENCE_RAW_DIR }}
+          IOS_EVIDENCE_EXPECTED_VERSION: 1.11.8+source-gated-enterprise-chat-candidate
+        run: |
+          python scripts/check_release_configuration.py --scope ios-evidence --format json --report-path dist/ios-evidence-preflight.json
+          python scripts/import_ios_real_device_evidence.py --raw-dir "$IOS_EVIDENCE_RAW_DIR" --expected-version "$IOS_EVIDENCE_EXPECTED_VERSION" --copy --write-report release/ios-real-device-evidence-import-report.json
+      - name: Import tri-app live smoke evidence
+        run: |
+          python scripts/check_release_configuration.py --scope tri-app-live-smoke --format json --report-path dist/tri-app-live-smoke-preflight.json
+          python scripts/import_tri_app_live_smoke_evidence.py --report "$TRI_APP_LIVE_SMOKE_REPORT_PATH" --expected-org-id "$TRI_APP_ORG_ID" --expected-scenario-id "$TRI_APP_LIVE_SMOKE_SCENARIO_ID" --copy --write-report release/tri-app-live-smoke-evidence-import-report.json
+      - run: python scripts/check_workflow_governance.py . --require-real-workflows
+      - run: python scripts/check_external_ga_evidence.py . --audit-only --write-report release/real-ga-evidence-audit-1.11.8.json
+      - uses: actions/upload-artifact
+        with:
+          name: real-ga-evidence-import-reports
+          path: |
+            dist/
+            release/real-ga-evidence-audit-1.11.8.json
+            release/ios-real-device-evidence-import-report.json
+            release/tri-app-live-smoke-evidence-import-report.json

diff --git a/Makefile b/Makefile
--- a/Makefile
+++ b/Makefile
@@
+IOS_EVIDENCE_RAW_DIR ?= /tmp/omnidesk-ios-real-device-evidence
+IOS_EVIDENCE_EXPECTED_VERSION ?= 1.11.8+source-gated-enterprise-chat-candidate
+ios-real-device-evidence-import:
+	IOS_EVIDENCE_RAW_DIR="$(IOS_EVIDENCE_RAW_DIR)" IOS_EVIDENCE_EXPECTED_VERSION="$(IOS_EVIDENCE_EXPECTED_VERSION)" $(PYTHON) scripts/check_release_configuration.py --scope ios-evidence --format json --report-path dist/ios-evidence-preflight.json
+	$(PYTHON) scripts/import_ios_real_device_evidence.py --raw-dir "$(IOS_EVIDENCE_RAW_DIR)" --expected-version "$(IOS_EVIDENCE_EXPECTED_VERSION)" --copy --write-report release/ios-real-device-evidence-import-report.json
+	$(PYTHON) scripts/check_external_ga_evidence.py . --audit-only --write-report release/real-ga-evidence-audit-1.11.8.json
+tri-app-live-smoke-preflight:
+	$(PYTHON) scripts/check_release_configuration.py --scope tri-app-live-smoke --format json --report-path dist/tri-app-live-smoke-preflight.json
+	$(PYTHON) scripts/import_tri_app_live_smoke_evidence.py --report "$${TRI_APP_LIVE_SMOKE_REPORT_PATH}" --expected-org-id "$${TRI_APP_ORG_ID}" --expected-scenario-id "$${TRI_APP_LIVE_SMOKE_SCENARIO_ID}" --copy --write-report release/tri-app-live-smoke-evidence-import-report.json
+workflow-governance-preflight:
+	$(PYTHON) scripts/check_workflow_governance.py . --require-real-workflows

diff --git a/scripts/import_ios_real_device_evidence.py b/scripts/import_ios_real_device_evidence.py
--- a/scripts/import_ios_real_device_evidence.py
+++ b/scripts/import_ios_real_device_evidence.py
@@
+VERSION = "1.11.8+source-gated-enterprise-chat-candidate"
+APNS_ARTIFACT_KINDS = {"apns_provider_receipt", "device_notification_log", "firebase_delivery_receipt"}
+# Validate native build exit_code, platform ios, explicit version, APNS artifact kind, no APNS .ipa proof, artifact SHA256, and source_native_artifact_sha256 consistency.

diff --git a/scripts/import_tri_app_live_smoke_evidence.py b/scripts/import_tri_app_live_smoke_evidence.py
--- a/scripts/import_tri_app_live_smoke_evidence.py
+++ b/scripts/import_tri_app_live_smoke_evidence.py
@@
+# Validate trace_id, started_at, finished_at, latency_ms, required tri-app steps, placeholders, and raw sensitive fields.

diff --git a/scripts/check_workflow_governance.py b/scripts/check_workflow_governance.py
--- a/scripts/check_workflow_governance.py
+++ b/scripts/check_workflow_governance.py
@@
+# Require --scope web-admin, --scope desktop, --scope mobile, --scope tri-app, --scope ios-evidence,
+# --scope tri-app-live-smoke, IOS_EVIDENCE_EXPECTED_VERSION, import_ios_real_device_evidence.py,
